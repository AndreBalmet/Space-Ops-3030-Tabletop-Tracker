{
  "rules": {
    "gameData": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "gameData_backup": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },

    "teams": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "deletedTeams": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "usernames": {
      "playtest1": { ".read": true },
      "playtest2": { ".read": true },
      "playtest3": { ".read": true },
      "playtest4": { ".read": true },
      "$name": {
        ".read": "auth != null",
        ".write": "auth != null && !data.exists() && newData.child('uid').val() === auth.uid"
      }
    },

    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },

    "players": {
      ".read": "auth != null",
      ".write": false
    },

    "sessions":  { ".read": false, ".write": false },
    "templates": { ".read": false, ".write": false },
    "admin":     { ".read": false, ".write": false }
  }
}
